{
  "dashboard": {
    "id": null,
    "uid": "vector-overview",
    "title": "Vector Metrics Dashboard",
    "tags": ["vector", "kubernetes", "logging"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "Vector Pods Running",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "count(vector_build_info)",
            "legendFormat": "Pods",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Total Events Processed",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "sum(increase(vector_processed_events_total[1h]))",
            "legendFormat": "Events/h",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Total Bytes Processed",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "sum(increase(vector_processed_bytes_total[1h]))",
            "legendFormat": "Bytes/h",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes"
          }
        }
      },
      {
        "id": 4,
        "type": "stat",
        "title": "Processing Errors",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "sum(increase(vector_component_errors_total[1h]))",
            "legendFormat": "Errors",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 10}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "type": "timeseries",
        "title": "Events Processed Rate",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "rate(vector_processed_events_total[5m])",
            "legendFormat": "{{pod}} - {{component_name}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "events/sec"
          }
        }
      },
      {
        "id": 6,
        "type": "timeseries",
        "title": "Bytes Processed Rate",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "rate(vector_processed_bytes_total[5m])",
            "legendFormat": "{{pod}} - {{component_name}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "Bps"
          }
        }
      },
      {
        "id": 7,
        "type": "timeseries",
        "title": "Component Errors",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "rate(vector_component_errors_total[5m])",
            "legendFormat": "{{pod}} - {{component_name}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "errors/sec"
          }
        }
      },
      {
        "id": 8,
        "type": "timeseries",
        "title": "Component Sent Events",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "rate(vector_component_sent_events_total[5m])",
            "legendFormat": "{{pod}} - {{component_name}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "events/sec"
          }
        }
      },
      {
        "id": 9,
        "type": "table",
        "title": "Vector Components Status",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "vector_component_sent_events_total",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "Value": false
              },
              "renameByName": {
                "component_name": "Component",
                "pod": "Pod",
                "namespace": "Namespace",
                "Value": "Sent Events"
              }
            }
          }
        ]
      },
      {
        "id": 10,
        "type": "timeseries",
        "title": "HTTP Requests",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
        "targets": [
          {
            "expr": "rate(vector_http_requests_total[5m])",
            "legendFormat": "{{method}} {{path}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 11,
        "type": "timeseries",
        "title": "HTTP Request Duration",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(vector_http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "95th percentile",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.99, rate(vector_http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "99th percentile",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 12,
        "type": "timeseries",
        "title": "Memory Usage by Pod",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 36},
        "targets": [
          {
            "expr": "container_memory_usage_bytes{container=\"vector\"}",
            "legendFormat": "{{pod}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes"
          }
        }
      },
      {
        "id": 13,
        "type": "timeseries",
        "title": "CPU Usage by Pod",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 36},
        "targets": [
          {
            "expr": "rate(container_cpu_usage_seconds_total{container=\"vector\"}[5m])",
            "legendFormat": "{{pod}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit"
          }
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "namespace",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(vector_build_info, namespace)",
          "refresh": 1,
          "includeAll": true,
          "multi": true
        },
        {
          "name": "pod",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(vector_build_info{namespace=~\"$namespace\"}, pod)",
          "refresh": 1,
          "includeAll": true,
          "multi": true
        },
        {
          "name": "component",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(vector_component_sent_events_total{namespace=~\"$namespace\"}, component_name)",
          "refresh": 1,
          "includeAll": true,
          "multi": true
        }
      ]
    }
  }
}
